---
/*
  Header
  ------
  Sticky top navigation. On mobile the nav collapses behind a hamburger;
  on `md:` and up the nav links render inline. Active section is marked
  with an accent-colored underline.

  Accessibility:
    - Hamburger is a real <button type="button"> with aria-expanded/aria-controls.
    - All links and the theme switcher rely on the global focus-visible ring.
    - Tap targets are ≥44px on mobile (p-2 + w-10/h-10 = 40px min, plus text).
*/

import ThemeSwitcher from './ThemeSwitcher.astro'

type Props = {
  section?: 'blog' | 'books' | 'speaking' | 'about'
}

const { section } = Astro.props

type NavItem = { label: string; href: string; key: Props['section'] }

const navItems: NavItem[] = [
  { label: 'Blog', href: '/blog', key: 'blog' },
  { label: 'Books', href: '/books', key: 'books' },
  { label: 'Speaking', href: '/speaking', key: 'speaking' },
  { label: 'About', href: '/about', key: 'about' },
]

const linkClasses = (isActive: boolean) =>
  [
    'block text-text-500 hover:text-primary-600 transition-colors rounded-sm',
    isActive
      ? 'underline underline-offset-8 decoration-4 decoration-accent-500 font-bold'
      : 'font-medium',
  ].join(' ')
---

<header
  class="sticky inset-x-0 top-0 z-50 bg-bg-500/95 backdrop-blur text-text-500 border-b border-transparent [&.is-scrolled]:border-bg-600"
>
  <nav
    class="mx-auto max-w-(--breakpoint-xl) px-8"
    aria-label="Primary navigation"
  >
    <div class="flex flex-wrap items-center justify-between mx-auto py-4">
      <a
        class="text-primary-500 hover:text-primary-700 font-bold hover:underline underline-offset-8 decoration-accent-500 rounded-sm"
        href="/">Luciano Mammino</a
      >
      <button
        data-collapse-toggle="navbar-default"
        type="button"
        class="inline-flex items-center p-2 w-11 h-11 justify-center text-sm text-text-500 rounded-md md:hidden hover:bg-bg-600 transition-colors"
        aria-controls="navbar-default"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="w-5 h-5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 17 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15"></path>
        </svg>
      </button>

      <div class="hidden w-full md:block md:w-auto" id="navbar-default">
        <ul
          class="flex flex-col gap-4 p-4 md:p-0 mt-4 border border-bg-600 rounded-lg bg-bg-100 md:flex-row md:items-center md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-transparent"
        >
          {
            navItems.map((item) => (
              <li>
                <a href={item.href}>
                  <div class={linkClasses(section === item.key)}>
                    {item.label}
                  </div>
                </a>
              </li>
            ))
          }
          <li><ThemeSwitcher /></li>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  const hamburgerBtn = document.querySelector(
    '[data-collapse-toggle]',
  ) as HTMLButtonElement
  if (hamburgerBtn) {
    hamburgerBtn.addEventListener('click', () => {
      const target = document.getElementById(
        hamburgerBtn.getAttribute('aria-controls')!,
      ) as HTMLElement
      const expanded = hamburgerBtn.getAttribute('aria-expanded') === 'true'
      hamburgerBtn.setAttribute('aria-expanded', (!expanded).toString())
      target!.classList.toggle('hidden')
    })
  }
</script>
