---
/*
  Button
  ------
  A standardized button / link component. Accepts either `variant` + `size`
  (preferred) or the legacy `isPrimary` boolean for backwards compatibility.

  Variants:
    - primary   deep indigo, high emphasis (default)
    - secondary slate, medium emphasis
    - ghost     transparent, low emphasis — blends into cards
  Sizes:
    - sm        py-1.5 px-3, text-sm  (min 40px tap target)
    - md        py-2   px-4, text-lg  (default, 44px tap target)
    - lg        py-3   px-6, text-xl  (hero CTAs)

  All states wired: hover, focus-visible, active, disabled.
  Focus-visible uses the global focus-ring token from global.css.
*/

type Variant = 'primary' | 'secondary' | 'ghost'
type Size = 'sm' | 'md' | 'lg'

interface Props {
  href?: string
  label?: string
  variant?: Variant
  size?: Size
  isDisabled?: boolean
  class?: string
  /** @deprecated use `variant="secondary"` instead — kept for backwards compat. */
  isPrimary?: boolean
}

const {
  href,
  label,
  isDisabled,
  isPrimary,
  variant: variantProp,
  size = 'md',
  class: classProp,
} = Astro.props

// Resolve variant from legacy `isPrimary` if provided.
const variant: Variant =
  variantProp ?? (isPrimary === false ? 'secondary' : 'primary')

const base =
  'inline-flex items-center justify-center gap-2 font-medium border-2 rounded-md transition-colors duration-[var(--duration-base)] ease-[var(--ease-standard)] select-none'

const sizes: Record<Size, string> = {
  sm: 'text-sm py-1.5 px-3 min-h-[40px]',
  md: 'text-lg py-2 px-4 min-h-[44px]',
  lg: 'text-xl py-3 px-6 min-h-[52px]',
}

const variants: Record<Variant, string> = {
  primary: [
    'bg-primary-600 text-bg-100 border-primary-600',
    'hover:bg-primary-700 hover:border-primary-700',
    'active:bg-primary-800 active:border-primary-800',
  ].join(' '),
  secondary: [
    'bg-secondary-600 text-bg-100 border-secondary-600',
    'hover:bg-secondary-700 hover:border-secondary-700',
    'active:bg-secondary-800 active:border-secondary-800',
  ].join(' '),
  ghost: [
    'bg-transparent text-text-500 border-text-200',
    'hover:bg-bg-400 hover:border-text-400',
    'active:bg-bg-600',
  ].join(' '),
}

const disabledClasses =
  'opacity-60 cursor-not-allowed bg-bg-400 text-text-300 border-bg-600 hover:bg-bg-400 hover:border-bg-600'

const composed = [
  base,
  sizes[size],
  isDisabled ? disabledClasses : variants[variant],
  classProp || '',
]
  .filter(Boolean)
  .join(' ')
---

{
  isDisabled ? (
    <span class={composed} aria-disabled="true">
      <slot>{label}</slot>
    </span>
  ) : (
    <a href={href} class={composed}>
      <slot>{label}</slot>
    </a>
  )
}
