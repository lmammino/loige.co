---
/*
  Prose
  -----
  Long-form article typography. Wraps children in a measured column
  (max-width ≈ 65-70ch) and applies @tailwindcss/typography styles with
  our design tokens.

  Width behaviour:
    By default, Prose constrains to --container-prose (~672px) for optimal
    line length. Pass `wide` to opt out (used by pages that intentionally
    want a full-bleed layout and handle their own width).

  Readability defaults:
    - Body text: text-text-400 (AA-safe on bg-500)
    - Headings:  text-text-500 (high contrast)
    - Links:     primary-700 underline with offset, animates to primary-500
    - First paragraph (lede): larger, slightly higher contrast
*/

import { clsx } from 'clsx'

type Props = {
  class?: string
  /** Opt out of the default measured reading column. */
  wide?: boolean
}

const { class: classProp, wide = false } = Astro.props
---

<article
  class={clsx(
    classProp,
    !wide && 'measure mx-auto',
    'text-text-400',
    'prose',
    'md:prose-lg',
    // Heading hierarchy — tighter tracking, balanced wrap.
    'prose-headings:text-text-500',
    'prose-headings:font-bold',
    'prose-headings:text-balance',
    'prose-h1:text-3xl md:prose-h1:text-4xl lg:prose-h1:text-5xl',
    // Body emphasis.
    'prose-strong:text-text-500',
    'prose-em:text-text-500',
    'prose-blockquote:text-text-500',
    'prose-blockquote:border-l-primary-500',
    'prose-blockquote:not-italic',
    // Lists / tables / figures.
    'prose-figcaption:text-text-300',
    'prose-ol:text-text-400',
    'prose-ul:text-text-400',
    'prose-li:text-text-400',
    'prose-table:text-text-400',
    'prose-thead:text-text-500',
    'prose-th:text-text-500',
    // Code — inline and block.
    'prose-code:text-text-500',
    'prose-code:font-normal',
    'prose-code:bg-bg-400',
    'prose-code:rounded',
    "prose-code:before:content-['']",
    "prose-code:after:content-['']",
    'prose-code:px-1.5',
    'prose-code:py-0.5',
    'prose-pre:bg-bg-300',
    'prose-pre:text-text-400',
    // Images and media.
    'prose-img:rounded-lg',
    'prose-img:shadow-md',
    // Rules.
    'prose-hr:border-text-100',
    // Links — underline with generous offset, animates on hover.
    'prose-a:underline',
    'prose-a:underline-offset-4',
    'prose-a:decoration-2',
    'prose-a:text-primary-700',
    'prose-a:decoration-text-200',
    'prose-a:hover:text-primary-500',
    'prose-a:hover:decoration-primary-500',
    'prose-a:transition-colors',
    // Lede — the first paragraph gets a touch more presence.
    '[&>p:first-of-type]:text-text-500',
    '[&>p:first-of-type]:text-lg/relaxed',
    'md:[&>p:first-of-type]:text-xl/relaxed',
  )}
>
  <slot />
</article>
