---
/*
  ThemeSwitcher
  -------------
  Toggles between `one-light` and `dark-plus` themes, persisted to localStorage.
  Uses design tokens for icon colours (not hardcoded slate/yellow) so both
  themes remain coherent.
*/

import Moon from './icons/Moon.astro'
import Sun from './icons/Sun.astro'
---

<button
  id="theme-switch"
  type="button"
  aria-label="Toggle colour theme"
  class="flex relative w-10 h-10 items-center justify-center rounded-md group hover:bg-bg-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
>
  <Moon
    id="moon"
    title="Switch theme to light mode"
    class="w-6 h-6 text-text-400 group-hover:text-text-500 absolute hidden group-hover:animate-wiggle"
  />
  <Sun
    id="sun"
    title="Switch theme to dark mode"
    class="w-6 h-6 text-accent-700 group-hover:text-accent-600 absolute hidden group-hover:animate-spin"
  />
</button>

<script>
  // theme-switcher
  let currentTheme = document.documentElement.getAttribute('data-theme')
  const moon = document.getElementById('moon') as any as SVGElement
  const sun = document.getElementById('sun') as any as SVGElement

  function updateIcon() {
    if (currentTheme === 'dark-plus') {
      moon.classList.remove('hidden')
      sun.classList.add('hidden')
    } else {
      moon.classList.add('hidden')
      sun.classList.remove('hidden')
    }
  }

  const themeSwitch = document.getElementById(
    'theme-switch',
  ) as HTMLButtonElement
  themeSwitch.addEventListener('click', (e) => {
    e.preventDefault()
    currentTheme = document.documentElement.getAttribute('data-theme')
    currentTheme = currentTheme === 'dark-plus' ? 'one-light' : 'dark-plus'
    document.documentElement.setAttribute('data-theme', currentTheme)
    localStorage.setItem('theme', currentTheme)
    updateIcon()
    const event = new Event('theme-changed') as Event & { theme: string }
    event.theme = currentTheme
    window.dispatchEvent(event)
  })

  updateIcon()
</script>
